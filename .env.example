# Server
PORT=8080

# Monitor tuning
CHECK_INTERVAL_MS=30000
REQUEST_TIMEOUT_MS=5000
MEMORY_SAMPLES_PER_SERVICE=20000

# PostgreSQL (recommended)
# You can keep credentials in DATABASE_URL,
# or set DATABASE_USERNAME / DATABASE_PASSWORD separately.
DATABASE_URL=postgres://localhost:5432/clash_status
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Services to check (JSON string)
SERVICES_JSON=[{"id":"api","name":"API","url":"https://api.clash.kr/"},{"id":"web","name":"Web","url":"https://clash.kr/"}]
